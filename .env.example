# Variables publicas del frontend. No agregar secretos aqui.
NEXT_PUBLIC_APP_NAME=Labora
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_ENABLE_GOOGLE_LOGIN=true

# Produccion / Netlify:
# Configurar estas mismas claves en Site configuration > Environment variables.
# NEXT_PUBLIC_APP_URL=https://labora.centralspike.com
# NEXT_PUBLIC_API_URL=https://labora.backend.centralspike.com/api/v1
#
# Nunca agregar GOOGLE_OAUTH_CLIENT_SECRET, JWT_SECRET, refresh tokens ni archivos
# client_secret_*.json al frontend.
